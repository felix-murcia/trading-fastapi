# ── n8n ───────────────────────────────────────────────────────────────────────
MASSIVE_API_KEY=
TELEGRAM_CHAT_ID=

# ── FastAPI / seguridad ───────────────────────────────────────────────────────
# Token que n8n envía en el header X-Internal-Token en cada request a FastAPI
INTERNAL_TOKEN=cambia_esto_por_un_token_aleatorio_seguro

# Clave para firmar el order_payload con HMAC-SHA256
# El EA MQL5 debe usar esta misma clave para verificar la firma (_sig)
HMAC_SECRET=cambia_esto_por_una_clave_hmac_aleatoria

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=cambia_esto_por_una_password_segura

# ── MT5 EA (socket TCP) ───────────────────────────────────────────────────────
MT5_SOCKET_PORT=9999

# ── LLM Providers ─────────────────────────────────────────────────────────────
# Proveedor activo: openrouter | gemini | groq
USE_PROVIDER=openrouter

OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=openai/gpt-4o-mini

GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions
GEMINI_MODEL=gemini-2.0-flash-lite

GROQ_API_KEY=
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile
