# ── FastAPI / seguridad ───────────────────────────────────────────────────────
# Token que el EA envía en el header X-Internal-Token en cada request a FastAPI
INTERNAL_TOKEN=cambia_esto_por_un_token_aleatorio_seguro

# Clave para firmar el order_payload con HMAC-SHA256
HMAC_SECRET=cambia_esto_por_una_clave_hmac_aleatoria

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=cambia_esto_por_una_password_segura

# ── MetaTrader MCP Server ────────────────────────────────────────────────────
MT5_HTTP_URL=http://YOUR_MT5_MCP_IP:8000

# ── Pipeline ─────────────────────────────────────────────────────────────────
SIMPLE_PIPELINE_ENABLED=true
SL_RISK_USD=15.0
SL_MULT=1.5     # multiplicador sobre distancia flecha→entrada (menor = SL más cercano, más volumen)
SL_PCT=0.001
